---
import './hero.scss';

import Button from '@components/ui/button/Button.astro';
import HeroInfo from './HeroInfo.vue';
---

<section class="hero">

  <!-- BACKGROUND -->

  <div class="hero__background">

    <img
      src={`${import.meta.env.BASE_URL}images/hero.webp`}
      alt=""
      loading="eager"
      decoding="async"
    />

  </div>

  <!-- OVERLAY -->

  <div class="hero__overlay"></div>

  <div class="hero__gradient"></div>

  <div class="container">

    <div class="hero__wrapper">

      <!-- LEFT -->

      <div class="hero__content">

        <div class="hero__badge">
          БЫСТРО • ЧЕСТНО • С ГАРАНТИЕЙ
        </div>

        <h1 class="hero__title">

          РЕМОНТ ТЕХНИКИ,
          <span>КОТОРАЯ НУЖНА</span>
          КАЖДЫЙ ДЕНЬ

        </h1>

        <p class="hero__description">

          Чиним компьютеры, телефоны,
          телевизоры и другую технику.
          Работаем без выходных
          и по адекватным ценам.

        </p>

        <div class="hero__actions">

          <Button text="Оставить заявку" />

        </div>

        <div class="hero__features">

          <div class="hero__feature">

            <div class="hero__feature-icon">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none"
              xmlns="http://www.w3.org/2000/svg">
                <circle cx="11" cy="11" r="6" stroke="#F7941D" stroke-width="2"/>
                <path d="M20 20L16.5 16.5" stroke="#2B1D16" stroke-width="2" stroke-linecap="round"/>
              </svg>
            </div>

            <div>

              <strong>Диагностика</strong>

              <button
                class="hero__feature-link"
                data-open-popup
              >
                Узнать цену
              </button>

            </div>

          </div>

          <div class="hero__feature">

            <div class="hero__feature-icon">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none"
xmlns="http://www.w3.org/2000/svg">
  <path d="M12 7V12L15 14" stroke="#F7941D" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
  <circle cx="12" cy="12" r="8" stroke="#2B1D16" stroke-width="2"/>
</svg>
            </div>

            <div>

              <strong>Ремонт</strong>

              <span>от 1 дня</span>

            </div>

          </div>

          <div class="hero__feature">

            <div class="hero__feature-icon">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none"
xmlns="http://www.w3.org/2000/svg">
  <path d="M12 3L19 6V11C19 16 15.5 19 12 21C8.5 19 5 16 5 11V6L12 3Z"
  stroke="#2B1D16" stroke-width="2" stroke-linejoin="round"/>
  <path d="M9 12L11 14L15 10"
  stroke="#F7941D" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
</svg>
            </div>

            <div>

              <strong>Гарантия</strong>

              <span>до 12 месяцев</span>

            </div>

          </div>

          <div class="hero__feature">

            <div class="hero__feature-icon">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none"
xmlns="http://www.w3.org/2000/svg">
  <path d="M6 7H18L17 18H7L6 7Z"
  stroke="#2B1D16" stroke-width="2" stroke-linejoin="round"/>
  <path d="M9 7C9 5.89543 9.89543 5 11 5H13C14.1046 5 15 5.89543 15 7"
  stroke="#2B1D16" stroke-width="2"/>
  <path d="M12 10V15"
  stroke="#F7941D" stroke-width="2" stroke-linecap="round"/>
  <path d="M10.5 12H13"
  stroke="#F7941D" stroke-width="2" stroke-linecap="round"/>
</svg>
            </div>

            <div>

              <strong>Честные цены</strong>

              <span>без доплат</span>

            </div>

          </div>

        </div>

      </div>

      <!-- RIGHT -->

      <HeroInfo />

    </div>

  </div>

</section>

<script>
  // Handle popup trigger for feature buttons
  document.addEventListener('click', (e) => {
    if ((e.target as Element)?.hasAttribute('data-open-popup')) {
      if (typeof window !== 'undefined') {
        window.dispatchEvent(new CustomEvent('open-lead-popup'));
      }
    }
  });
</script>